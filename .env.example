# Postgres connection. Prisma uses DATABASE_URL for the app (restricted) role
# and DIRECT_URL for migrations. In local dev they can be the same.
DATABASE_URL="postgresql://app_role:app_pass@localhost:5432/lingo_cars?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lingo_cars?schema=public"

PORT=3000
